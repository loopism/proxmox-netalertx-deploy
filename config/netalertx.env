# NetAlertX Environment Configuration File
# This file contains environment variables and configuration options for NetAlertX deployment
# Copy this file and modify it according to your needs

# ============================================================================
# CONTAINER CONFIGURATION
# ============================================================================

# User and Group IDs (should match the container's user)
PUID=1000
PGID=1000

# Timezone setting (change to your local timezone)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# Web interface port
PORT=20211

# GraphQL API port
GRAPHQL_PORT=20212

# Listen address (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
LISTEN_ADDR=0.0.0.0

# ============================================================================
# SCANNING CONFIGURATION
# ============================================================================

# Network subnets to scan (JSON array format)
# Examples:
# - Single subnet: ["192.168.1.0/24"]
# - Multiple subnets: ["192.168.1.0/24", "10.0.0.0/24"]
# - With interface specification: ["192.168.1.0/24 --interface=eth0"]
SCAN_SUBNETS=["192.168.1.0/24"]

# ARP scan timeout (seconds)
ARPSCAN_RUN_TIMEOUT=30

# Scan interval (minutes)
SCAN_CYCLE_MINUTES=5

# ============================================================================
# PLUGIN CONFIGURATION
# ============================================================================

# Plugins to load (JSON array format)
# Available plugins: ARPSCAN, PIHOLE, DHCP_LEASES, UNIFI, SNMP, NMAP, etc.
# Examples:
# - Basic: ["ARPSCAN"]
# - With Pi-hole: ["ARPSCAN", "PIHOLE"]
# - Full featured: ["ARPSCAN", "PIHOLE", "DHCP_LEASES", "NMAP"]
LOADED_PLUGINS=["ARPSCAN"]

# ============================================================================
# DATABASE AND LOGGING
# ============================================================================

# Database path (usually don't change this)
DB_PATH=/app/db/app.db

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log path (usually don't change this)
LOG_PATH=/app/log/

# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================

# NTFY Notification Service
NTFY_ENABLED=False
NTFY_URL=
NTFY_TOPIC=

# Pushover Notification Service
PUSHOVER_ENABLED=False
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Pushsafer Notification Service
PUSHSAFER_ENABLED=False
PUSHSAFER_TOKEN=

# Apprise Notification Service (supports 80+ services)
APPRISE_ENABLED=False
APPRISE_URL=

# ============================================================================
# WEB INTERFACE SETTINGS
# ============================================================================

# Dashboard URL (for notifications and reports)
REPORT_DASHBOARD_URL=http://localhost:20211

# Report language
REPORT_LANGUAGE=English

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Enable/disable authentication (if supported in your version)
AUTH_ENABLED=False

# API key for external access (if supported)
API_KEY=

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================

# Enable development mode (more verbose logging)
DEV_MODE=False

# Custom configuration override (JSON format)
# This allows you to override any setting not covered above
# Example: {"CUSTOM_SETTING": "value", "ANOTHER_SETTING": 123}
APP_CONF_OVERRIDE={}

# Always perform fresh install (WARNING: deletes existing data)
ALWAYS_FRESH_INSTALL=False

# ============================================================================
# PI-HOLE INTEGRATION (if using PIHOLE plugin)
# ============================================================================

# Pi-hole database path (if running on same host)
PIHOLE_DB_PATH=

# Pi-hole API URL (if running on different host)
PIHOLE_API_URL=

# Pi-hole API token
PIHOLE_API_TOKEN=

# ============================================================================
# DHCP INTEGRATION (if using DHCP_LEASES plugin)
# ============================================================================

# DHCP leases file path
DHCP_LEASES_PATH=/var/lib/dhcp/dhcpd.leases

# ============================================================================
# UNIFI INTEGRATION (if using UNIFI plugin)
# ============================================================================

# UniFi controller URL
UNIFI_URL=

# UniFi username
UNIFI_USERNAME=

# UniFi password
UNIFI_PASSWORD=

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================

# Maximum number of concurrent scans
MAX_CONCURRENT_SCANS=3

# Scan timeout (seconds)
SCAN_TIMEOUT=60

# Database cleanup interval (days)
DB_CLEANUP_INTERVAL=30

# Keep scan history for X days
KEEP_SCAN_HISTORY_DAYS=90
